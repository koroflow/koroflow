{
	"extends": "@koroflow/typescript-config/react-library.json",
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["esnext", "dom"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["vitest/globals", "@vitest/browser/providers/playwright"],
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
